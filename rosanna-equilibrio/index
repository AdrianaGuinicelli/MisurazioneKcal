<!DOCTYPE html>
<html lang="it">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Rosanna in Equilibrio</title>
  <style>
    :root {
      --primary: #6FA8DC;
      --secondary: #A8D5BA;
      --bg: #F9FAF7;
      --card: #FFFFFF;
      --text: #2F3A45;
      --muted: #6B7280;
      --accent: #F4B6A6;
      --danger: #E57373;
      --success: #5BAE7A;
      --border: #E5E7EB;
      --shadow: 0 8px 24px rgba(0,0,0,0.08);
      --radius: 18px;
    }

    * {
      box-sizing: border-box;
    }

    body {
      margin: 0;
      font-family: Arial, Helvetica, sans-serif;
      background: var(--bg);
      color: var(--text);
    }

    .app {
      max-width: 760px;
      margin: 0 auto;
      padding: 16px 16px 100px;
    }

    .header {
      background: linear-gradient(135deg, var(--primary), #8cc3ee);
      color: white;
      padding: 22px 18px;
      border-radius: 22px;
      box-shadow: var(--shadow);
      margin-bottom: 16px;
    }

    .header h1 {
      margin: 0 0 8px;
      font-size: 28px;
    }

    .header p {
      margin: 0;
      font-size: 16px;
      opacity: 0.95;
    }

    .tabs {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 8px;
      margin-bottom: 16px;
    }

    .tab-btn {
      border: none;
      background: white;
      color: var(--text);
      padding: 14px 10px;
      border-radius: 14px;
      font-size: 15px;
      font-weight: bold;
      box-shadow: var(--shadow);
      cursor: pointer;
    }

    .tab-btn.active {
      background: var(--secondary);
    }

    .section {
      display: none;
    }

    .section.active {
      display: block;
    }

    .card {
      background: var(--card);
      border-radius: var(--radius);
      padding: 18px;
      box-shadow: var(--shadow);
      margin-bottom: 16px;
      border: 1px solid var(--border);
    }

    .card h2, .card h3 {
      margin-top: 0;
    }

    .metrics {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 12px;
    }

    .metric {
      background: #f8fbff;
      border: 1px solid #dbeafe;
      border-radius: 16px;
      padding: 14px;
    }

    .metric.green {
      background: #f4fbf6;
      border-color: #d1fae5;
    }

    .metric .label {
      font-size: 13px;
      color: var(--muted);
      margin-bottom: 6px;
    }

    .metric .value {
      font-size: 24px;
      font-weight: bold;
    }

    .bar-wrap {
      margin-top: 12px;
    }

    .bar-label {
      font-size: 14px;
      margin: 0 0 6px;
      color: var(--muted);
    }

    .bar-bg {
      width: 100%;
      height: 14px;
      background: #edf2f7;
      border-radius: 999px;
      overflow: hidden;
    }

    .bar-fill {
      height: 100%;
      border-radius: 999px;
    }

    .bar-fill.blue {
      background: var(--primary);
    }

    .bar-fill.green {
      background: var(--success);
    }

    .grid-2 {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 12px;
    }

    .field {
      margin-bottom: 12px;
    }

    .field label {
      display: block;
      font-size: 14px;
      font-weight: bold;
      margin-bottom: 6px;
    }

    .field input,
    .field select,
    .field textarea {
      width: 100%;
      padding: 14px;
      border: 1px solid var(--border);
      border-radius: 14px;
      font-size: 16px;
      background: white;
    }

    .field textarea {
      resize: vertical;
      min-height: 90px;
    }

    .btn {
      width: 100%;
      border: none;
      padding: 15px 16px;
      border-radius: 16px;
      font-size: 16px;
      font-weight: bold;
      cursor: pointer;
      margin-top: 6px;
    }

    .btn-primary {
      background: var(--primary);
      color: white;
    }

    .btn-secondary {
      background: var(--secondary);
      color: var(--text);
    }

    .btn-accent {
      background: var(--accent);
      color: var(--text);
    }

    .small-text {
      font-size: 13px;
      color: var(--muted);
    }

    .status {
      padding: 12px 14px;
      border-radius: 14px;
      margin-bottom: 12px;
      display: none;
      font-size: 14px;
    }

    .status.show {
      display: block;
    }

    .status.success {
      background: #edfdf3;
      color: #166534;
      border: 1px solid #bbf7d0;
    }

    .status.error {
      background: #fef2f2;
      color: #991b1b;
      border: 1px solid #fecaca;
    }

    .suggestion {
      padding: 12px;
      border-radius: 14px;
      background: #f8fbff;
      border: 1px solid #dbeafe;
      margin-bottom: 10px;
    }

    .suggestion h4 {
      margin: 0 0 6px;
    }

    .list {
      margin: 0;
      padding-left: 18px;
    }

    .history-item {
      padding: 12px;
      border: 1px solid var(--border);
      border-radius: 14px;
      margin-bottom: 10px;
      background: #fff;
    }

    .footer-nav {
      position: fixed;
      bottom: 0;
      left: 0;
      right: 0;
      background: rgba(255,255,255,0.95);
      border-top: 1px solid var(--border);
      display: flex;
      justify-content: center;
      backdrop-filter: blur(8px);
    }

    .footer-nav-inner {
      max-width: 760px;
      width: 100%;
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 8px;
      padding: 10px 16px calc(10px + env(safe-area-inset-bottom));
    }

    .footer-btn {
      border: none;
      background: white;
      border-radius: 14px;
      padding: 12px 8px;
      font-size: 14px;
      font-weight: bold;
      box-shadow: var(--shadow);
      cursor: pointer;
    }

    .footer-btn.active {
      background: var(--secondary);
    }

    @media (max-width: 640px) {
      .metrics,
      .grid-2,
      .tabs {
        grid-template-columns: 1fr;
      }

      .header h1 {
        font-size: 24px;
      }

      .metric .value {
        font-size: 22px;
      }
    }
  </style>
</head>
<body>
  <div class="app">
    <div class="header">
      <h1>Rosanna in Equilibrio</h1>
      <p>Un aiuto semplice e sereno per seguire la giornata.</p>
    </div>

    <div id="statusBox" class="status"></div>

    <div class="tabs">
      <button class="tab-btn active" onclick="showSection('home', this)">Home</button>
      <button class="tab-btn" onclick="showSection('inserisci', this)">Inserisci</button>
      <button class="tab-btn" onclick="showSection('storico', this)">Storico</button>
    </div>

    <!-- HOME -->
    <section id="home" class="section active">
      <div class="card">
        <h2>Ciao Rosanna</h2>
        <p class="small-text">Qui puoi vedere come sta andando la giornata di oggi.</p>

        <div class="metrics">
          <div class="metric">
            <div class="label">Kcal assunte oggi</div>
            <div id="todayCalories" class="value">0</div>
          </div>
          <div class="metric green">
            <div class="label">Kcal consumate con attività</div>
            <div id="todayBurned" class="value">0</div>
          </div>
          <div class="metric">
            <div class="label">Mantenimento</div>
            <div id="maintenanceCalories" class="value">1700</div>
          </div>
          <div class="metric green">
            <div class="label">Obiettivo dimagrimento</div>
            <div id="goalCalories" class="value">1440</div>
          </div>
        </div>

        <div class="bar-wrap">
          <p class="bar-label">Avanzamento rispetto al mantenimento</p>
          <div class="bar-bg">
            <div id="maintenanceBar" class="bar-fill blue" style="width:0%"></div>
          </div>
        </div>

        <div class="bar-wrap">
          <p class="bar-label">Avanzamento rispetto all’obiettivo</p>
          <div class="bar-bg">
            <div id="goalBar" class="bar-fill green" style="width:0%"></div>
          </div>
        </div>

        <div class="grid-2" style="margin-top:14px;">
          <div class="metric">
            <div class="label">Residuo mantenimento</div>
            <div id="remainingMaintenance" class="value">0</div>
          </div>
          <div class="metric green">
            <div class="label">Residuo obiettivo</div>
            <div id="remainingGoal" class="value">0</div>
          </div>
        </div>
      </div>

      <div class="card">
        <h3>Macronutrienti di oggi</h3>
        <div class="metrics">
          <div class="metric">
            <div class="label">Proteine</div>
            <div id="todayProteins" class="value">0 g</div>
          </div>
          <div class="metric">
            <div class="label">Carboidrati</div>
            <div id="todayCarbs" class="value">0 g</div>
          </div>
          <div class="metric">
            <div class="label">Grassi</div>
            <div id="todayFats" class="value">0 g</div>
          </div>
          <div class="metric green">
            <div class="label">Bilancio netto</div>
            <div id="todayNet" class="value">0</div>
          </div>
        </div>
      </div>

      <div class="card">
        <h3>Suggerimento per il prossimo pasto</h3>
        <p class="small-text">Il suggerimento si basa su orario, calorie residue, macronutrienti e preferenze.</p>
        <button class="btn btn-secondary" onclick="loadSuggestions()">Suggeriscimi cosa mangiare</button>
        <div id="suggestionsBox" style="margin-top: 14px;"></div>
      </div>
    </section>

    <!-- INSERISCI -->
    <section id="inserisci" class="section">
      <div class="card">
        <h2>Aggiungi alimento</h2>

        <div class="field">
          <label for="foodName">Alimento</label>
          <input id="foodName" type="text" placeholder="Es. pasta, mela, yogurt..." />
        </div>

        <div class="grid-2">
          <div class="field">
            <label for="foodQuantity">Quantità (g)</label>
            <input id="foodQuantity" type="number" placeholder="Es. 80" />
          </div>
          <div class="field">
            <label for="mealType">Pasto</label>
            <select id="mealType">
              <option value="colazione">Colazione</option>
              <option value="spuntino_mattutino">Spuntino mattutino</option>
              <option value="pranzo">Pranzo</option>
              <option value="spuntino_pomeridiano">Spuntino pomeridiano</option>
              <option value="cena">Cena</option>
              <option value="extra">Extra</option>
            </select>
          </div>
        </div>

        <div class="grid-2">
          <div class="field">
            <label for="foodDate">Data</label>
            <input id="foodDate" type="date" />
          </div>
          <div class="field">
            <label for="foodTime">Ora</label>
            <input id="foodTime" type="time" />
          </div>
        </div>

        <button class="btn btn-primary" onclick="saveFood()">Salva alimento</button>
      </div>

      <div class="card">
        <h2>Aggiungi attività</h2>

        <div class="field">
          <label for="activityType">Attività</label>
          <select id="activityType">
            <option value="camminata_lenta">Camminata lenta</option>
            <option value="camminata_moderata">Camminata moderata</option>
            <option value="camminata_sostenuta">Camminata sostenuta</option>
            <option value="ginnastica_leggera">Ginnastica leggera</option>
          </select>
        </div>

        <div class="grid-2">
          <div class="field">
            <label for="activityDuration">Durata (minuti)</label>
            <input id="activityDuration" type="number" placeholder="Es. 20" />
          </div>
          <div class="field">
            <label for="activityIntensity">Intensità</label>
            <select id="activityIntensity">
              <option value="lieve">Lieve</option>
              <option value="moderata">Moderata</option>
              <option value="sostenuta">Sostenuta</option>
            </select>
          </div>
        </div>

        <div class="grid-2">
          <div class="field">
            <label for="activityDate">Data</label>
            <input id="activityDate" type="date" />
          </div>
          <div class="field">
            <label for="activityTime">Ora</label>
            <input id="activityTime" type="time" />
          </div>
        </div>

        <button class="btn btn-secondary" onclick="saveActivity()">Salva attività</button>
      </div>

      <div class="card">
        <h2>Preferenze alimentari</h2>

        <div class="field">
          <label for="preferenceFood">Alimento</label>
          <input id="preferenceFood" type="text" placeholder="Es. zucchine, yogurt, cavolfiore..." />
        </div>

        <div class="field">
          <label for="preferenceType">Tipo preferenza</label>
          <select id="preferenceType">
            <option value="preferito">Preferito</option>
            <option value="non_gradito">Non gradito</option>
          </select>
        </div>

        <button class="btn btn-accent" onclick="savePreference()">Salva preferenza</button>
      </div>

      <div class="card">
        <h2>Obiettivo di dimagrimento</h2>

        <div class="grid-2">
          <div class="field">
            <label for="goalKg">Kg da perdere</label>
            <input id="goalKg" type="number" step="0.1" placeholder="Es. 3" />
          </div>
          <div class="field">
            <label for="goalDays">Entro quanti giorni</label>
            <input id="goalDays" type="number" placeholder="Es. 90" />
          </div>
        </div>

        <button class="btn btn-primary" onclick="saveGoal()">Salva obiettivo</button>
        <p class="small-text" style="margin-top:10px;">
          L’app manterrà visibili sia il riferimento di mantenimento sia quello con deficit calorico.
        </p>
      </div>
    </section>

    <!-- STORICO -->
    <section id="storico" class="section">
      <div class="card">
        <h2>Storico giornaliero</h2>
        <p class="small-text">Qui puoi rivedere gli ultimi inserimenti della giornata.</p>
        <button class="btn btn-secondary" onclick="loadHistory()">Aggiorna storico</button>
        <div id="historyBox" style="margin-top:14px;"></div>
      </div>

      <div class="card">
        <h2>Analisi veloce</h2>
        <ul class="list" id="analysisBox">
          <li>Nessun dato disponibile al momento.</li>
        </ul>
      </div>
    </section>
  </div>

  <div class="footer-nav">
    <div class="footer-nav-inner">
      <button class="footer-btn active" onclick="footerShow('home', this)">Home</button>
      <button class="footer-btn" onclick="footerShow('inserisci', this)">Inserisci</button>
      <button class="footer-btn" onclick="footerShow('storico', this)">Storico</button>
    </div>
  </div>

  <script>
    /*
      INSERISCI QUI L'URL DEL TUO GOOGLE APPS SCRIPT WEB APP
      Esempio:
      const API_BASE = "https://script.google.com/macros/s/AKfycb.../exec";
    */
    const API_BASE = "INCOLLA_QUI_L_URL_DEL_TUO_APPS_SCRIPT";

    function todayISODate() {
      const d = new Date();
      return d.toISOString().split('T')[0];
    }

    function currentTimeHHMM() {
      const d = new Date();
      return d.toTimeString().slice(0, 5);
    }

    function initDefaults() {
      document.getElementById('foodDate').value = todayISODate();
      document.getElementById('foodTime').value = currentTimeHHMM();
      document.getElementById('activityDate').value = todayISODate();
      document.getElementById('activityTime').value = currentTimeHHMM();
    }

    function showSection(sectionId, clickedBtn = null) {
      document.querySelectorAll('.section').forEach(sec => sec.classList.remove('active'));
      document.getElementById(sectionId).classList.add('active');

      document.querySelectorAll('.tab-btn').forEach(btn => btn.classList.remove('active'));
      if (clickedBtn) clickedBtn.classList.add('active');

      document.querySelectorAll('.footer-btn').forEach(btn => btn.classList.remove('active'));
      const footerBtns = document.querySelectorAll('.footer-btn');
      if (sectionId === 'home') footerBtns[0].classList.add('active');
      if (sectionId === 'inserisci') footerBtns[1].classList.add('active');
      if (sectionId === 'storico') footerBtns[2].classList.add('active');
    }

    function footerShow(sectionId, clickedBtn) {
      showSection(sectionId);
      document.querySelectorAll('.footer-btn').forEach(btn => btn.classList.remove('active'));
      clickedBtn.classList.add('active');

      document.querySelectorAll('.tab-btn').forEach(btn => btn.classList.remove('active'));
      const topBtns = document.querySelectorAll('.tab-btn');
      if (sectionId === 'home') topBtns[0].classList.add('active');
      if (sectionId === 'inserisci') topBtns[1].classList.add('active');
      if (sectionId === 'storico') topBtns[2].classList.add('active');
    }

    function showStatus(message, type = 'success') {
      const box = document.getElementById('statusBox');
      box.textContent = message;
      box.className = `status show ${type}`;
      setTimeout(() => {
        box.className = 'status';
      }, 3500);
    }

    async function apiRequest(action, payload = {}) {
      if (!API_BASE || API_BASE.includes('INCOLLA_QUI')) {
        throw new Error('URL Apps Script non configurato.');
      }

      const response = await fetch(API_BASE, {
        method: 'POST',
        headers: { 'Content-Type': 'text/plain;charset=utf-8' },
        body: JSON.stringify({ action, ...payload })
      });

      const text = await response.text();

      try {
        return JSON.parse(text);
      } catch (err) {
        throw new Error('Risposta non valida dal server: ' + text);
      }
    }

    async function loadDashboard() {
      try {
        const res = await apiRequest('getDashboard', { date: todayISODate() });

        const data = res.data || {};
        const consumed = Number(data.totalKcalIn || 0);
        const burned = Number(data.totalKcalOut || 0);
        const maintenance = Number(data.maintenanceKcal || 1700);
        const goal = Number(data.goalKcal || 1440);
        const proteins = Number(data.proteinG || 0);
        const carbs = Number(data.carbsG || 0);
        const fats = Number(data.fatG || 0);

        document.getElementById('todayCalories').textContent = Math.round(consumed);
        document.getElementById('todayBurned').textContent = Math.round(burned);
        document.getElementById('maintenanceCalories').textContent = Math.round(maintenance);
        document.getElementById('goalCalories').textContent = Math.round(goal);
        document.getElementById('remainingMaintenance').textContent = Math.round(maintenance - consumed);
        document.getElementById('remainingGoal').textContent = Math.round(goal - consumed);
        document.getElementById('todayProteins').textContent = Math.round(proteins) + ' g';
        document.getElementById('todayCarbs').textContent = Math.round(carbs) + ' g';
        document.getElementById('todayFats').textContent = Math.round(fats) + ' g';
        document.getElementById('todayNet').textContent = Math.round(consumed - burned);

        const maintenancePct = Math.min((consumed / maintenance) * 100, 100);
        const goalPct = Math.min((consumed / goal) * 100, 100);

        document.getElementById('maintenanceBar').style.width = maintenancePct + '%';
        document.getElementById('goalBar').style.width = goalPct + '%';

        updateQuickAnalysis(data);
      } catch (error) {
        showStatus(error.message, 'error');
      }
    }

    function updateQuickAnalysis(data) {
      const analysisBox = document.getElementById('analysisBox');
      const consumed = Number(data.totalKcalIn || 0);
      const maintenance = Number(data.maintenanceKcal || 1700);
      const goal = Number(data.goalKcal || 1440);
      const protein = Number(data.proteinG || 0);
      const carbs = Number(data.carbsG || 0);
      const fats = Number(data.fatG || 0);

      const items = [];

      if (consumed <= goal) {
        items.push("Oggi sei dentro al tuo obiettivo calorico.");
      } else if (consumed <= maintenance) {
        items.push("Oggi sei sopra il target di dimagrimento, ma ancora sotto il mantenimento.");
      } else {
        items.push("Oggi hai superato il livello stimato di mantenimento.");
      }

      if (protein < 50) {
        items.push("Le proteine di oggi sembrano un po’ basse.");
      }

      if (carbs > protein * 3) {
        items.push("I carboidrati sono abbastanza alti rispetto alle proteine.");
      }

      if (fats > 70) {
        items.push("I grassi di oggi risultano piuttosto elevati.");
      }

      analysisBox.innerHTML = items.length
        ? items.map(item => `<li>${item}</li>`).join('')
        : `<li>Nessuna analisi disponibile.</li>`;
    }

    async function saveFood() {
      const foodName = document.getElementById('foodName').value.trim();
      const quantity = Number(document.getElementById('foodQuantity').value);
      const mealType = document.getElementById('mealType').value;
      const date = document.getElementById('foodDate').value;
      const time = document.getElementById('foodTime').value;

      if (!foodName || !quantity || !date || !time) {
        showStatus('Compila tutti i campi dell’alimento.', 'error');
        return;
      }

      try {
        const res = await apiRequest('saveFood', {
          foodName,
          quantity,
          mealType,
          date,
          time
        });

        showStatus(res.message || 'Alimento salvato con successo.');
        document.getElementById('foodName').value = '';
        document.getElementById('foodQuantity').value = '';
        await loadDashboard();
        await loadHistory();
      } catch (error) {
        showStatus(error.message, 'error');
      }
    }

    async function saveActivity() {
      const activityType = document.getElementById('activityType').value;
      const durationMinutes = Number(document.getElementById('activityDuration').value);
      const intensity = document.getElementById('activityIntensity').value;
      const date = document.getElementById('activityDate').value;
      const time = document.getElementById('activityTime').value;

      if (!activityType || !durationMinutes || !date || !time) {
        showStatus('Compila tutti i campi dell’attività.', 'error');
        return;
      }

      try {
        const res = await apiRequest('saveActivity', {
          activityType,
          durationMinutes,
          intensity,
          date,
          time
        });

        showStatus(res.message || 'Attività salvata con successo.');
        document.getElementById('activityDuration').value = '';
        await loadDashboard();
        await loadHistory();
      } catch (error) {
        showStatus(error.message, 'error');
      }
    }

    async function savePreference() {
      const foodName = document.getElementById('preferenceFood').value.trim();
      const preferenceType = document.getElementById('preferenceType').value;

      if (!foodName) {
        showStatus('Inserisci l’alimento della preferenza.', 'error');
        return;
      }

      try {
        const res = await apiRequest('savePreference', {
          foodName,
          preferenceType
        });

        showStatus(res.message || 'Preferenza salvata con successo.');
        document.getElementById('preferenceFood').value = '';
      } catch (error) {
        showStatus(error.message, 'error');
      }
    }

    async function saveGoal() {
      const kgToLose = Number(document.getElementById('goalKg').value);
      const days = Number(document.getElementById('goalDays').value);

      if (!kgToLose || !days) {
        showStatus('Inserisci kg da perdere e numero di giorni.', 'error');
        return;
      }

      try {
        const res = await apiRequest('saveGoal', {
          kgToLose,
          days
        });

        showStatus(res.message || 'Obiettivo salvato con successo.');
        await loadDashboard();
      } catch (error) {
        showStatus(error.message, 'error');
      }
    }

    async function loadSuggestions() {
      const box = document.getElementById('suggestionsBox');
      box.innerHTML = '<p class="small-text">Sto preparando i suggerimenti...</p>';

      try {
        const res = await apiRequest('getSuggestions', {
          date: todayISODate(),
          time: currentTimeHHMM()
        });

        const suggestions = res.data?.suggestions || [];

        if (!suggestions.length) {
          box.innerHTML = '<p class="small-text">Nessun suggerimento disponibile al momento.</p>';
          return;
        }

        box.innerHTML = suggestions.map(item => `
          <div class="suggestion">
            <h4>${item.title || 'Suggerimento'}</h4>
            <p>${item.description || ''}</p>
            <p class="small-text">
              ${item.kcal ? `Kcal stimate: ${item.kcal}` : ''}
              ${item.macros ? ` · Macro: ${item.macros}` : ''}
            </p>
          </div>
        `).join('');
      } catch (error) {
        box.innerHTML = '';
        showStatus(error.message, 'error');
      }
    }

    async function loadHistory() {
      const box = document.getElementById('historyBox');
      box.innerHTML = '<p class="small-text">Carico lo storico...</p>';

      try {
        const res = await apiRequest('getHistory', { date: todayISODate() });
        const foodLogs = res.data?.foodLogs || [];
        const activityLogs = res.data?.activityLogs || [];

        if (!foodLogs.length && !activityLogs.length) {
          box.innerHTML = '<p class="small-text">Nessun inserimento per oggi.</p>';
          return;
        }

        let html = '';

        if (foodLogs.length) {
          html += '<h3>Alimenti</h3>';
          html += foodLogs.map(item => `
            <div class="history-item">
              <strong>${item.time || ''} - ${item.foodName || ''}</strong><br>
              Quantità: ${item.quantity || 0} g<br>
              Kcal: ${Math.round(item.kcal || 0)}<br>
              Macro: P ${Math.round(item.protein || 0)}g · C ${Math.round(item.carbs || 0)}g · G ${Math.round(item.fat || 0)}g<br>
              Pasto: ${item.mealType || '-'}
            </div>
          `).join('');
        }

        if (activityLogs.length) {
          html += '<h3>Attività</h3>';
          html += activityLogs.map(item => `
            <div class="history-item">
              <strong>${item.time || ''} - ${item.activityType || ''}</strong><br>
              Durata: ${item.durationMinutes || 0} minuti<br>
              Intensità: ${item.intensity || '-'}<br>
              Kcal consumate: ${Math.round(item.kcalBurned || 0)}
            </div>
          `).join('');
        }

        box.innerHTML = html;
      } catch (error) {
        box.innerHTML = '';
        showStatus(error.message, 'error');
      }
    }

    window.addEventListener('load', async () => {
      initDefaults();
      await loadDashboard();
      await loadHistory();
    });
  </script>
</body>
</html>
